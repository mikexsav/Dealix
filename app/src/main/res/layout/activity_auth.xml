<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".AuthActivity">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="600dp"
        android:scaleType="centerCrop"
        android:src="@drawable/main_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <ImageView
        android:id="@+id/image"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:lineHeight="32sp"
        android:text="Добрый вечер,\nавторизуйтесь"
        android:textColor="@color/white"
        android:textSize="24sp"
        app:layout_constraintStart_toStartOf="@+id/image"
        app:layout_constraintTop_toBottomOf="@+id/image" />

    <LinearLayout
        android:layout_marginTop="12dp"
        android:id="@+id/pinContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView11">

        <View
            android:id="@+id/pin1"
            style="@style/PinBox" />

        <View
            android:id="@+id/pin2"
            style="@style/PinBox" />

        <View
            android:id="@+id/pin3"
            style="@style/PinBox" />

        <View
            android:id="@+id/pin4"
            style="@style/PinBox" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/keyboard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:columnCount="3"
        android:rowCount="4"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/btnBiometric"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pinContainer">

        <TextView
            android:id="@+id/btn1"
            style="@style/PinKeySimple"
            android:text="1" />

        <TextView
            android:id="@+id/btn2"
            style="@style/PinKeySimple"
            android:text="2" />

        <TextView
            android:id="@+id/btn3"
            style="@style/PinKeySimple"
            android:text="3" />

        <TextView
            android:id="@+id/btn4"
            style="@style/PinKeySimple"
            android:text="4" />

        <TextView
            android:id="@+id/btn5"
            style="@style/PinKeySimple"
            android:text="5" />

        <TextView
            android:id="@+id/btn6"
            style="@style/PinKeySimple"
            android:text="6" />

        <TextView
            android:id="@+id/btn7"
            style="@style/PinKeySimple"
            android:text="7" />

        <TextView
            android:id="@+id/btn8"
            style="@style/PinKeySimple"
            android:text="8" />

        <TextView
            android:id="@+id/btn9"
            style="@style/PinKeySimple"
            android:text="9" />

        <View
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_columnWeight="1" />

        <TextView
            android:id="@+id/btn0"
            style="@style/PinKeySimple"
            android:text="0" />

        <TextView
            android:id="@+id/btnDelete"
            style="@style/PinKeySimple"
            android:text="⌫" />

    </GridLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btnBiometric"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/back_green"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/auth"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Войти по биометрии"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/auth"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/back_green"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Авторизоваться"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.vk.id.onetap.xml.OneTapBottomSheet
        android:id="@+id/vkid_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:vkid_autoHideOnSuccess="false"
        app:vkid_bottomSheetScenario="EnterToAccount"
        app:vkid_bottomSheetServiceName="СБЕР Дилер" />

</androidx.constraintlayout.widget.ConstraintLayout>