<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Spring_2026" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="fontFamily">@font/jost</item>
    </style>

    <style name="PinBox">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:background">@drawable/bg_pin_empty</item>
    </style>

    <style name="GreenIndicator">
        <item name="android:color">@android:color/transparent</item>
        <item name="shapeAppearance">@style/RoundedIndicator</item>
    </style>

    <style name="RoundedIndicator">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="PinKeySimple">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">24sp</item>
        <item name="android:background">@drawable/bg_pin_key</item>
    </style>


    <style name="Theme.Spring_2026" parent="Base.Theme.Spring_2026" />

    <style name="Theme.Spring_2026.AppWidgetContainerParent" parent="@android:style/Theme.DeviceDefault">
        <!-- Radius of the outer bound of widgets to make the rounded corners -->
        <item name="appWidgetRadius">16dp</item>
        <!--
        Radius of the inner view's bound of widgets to make the rounded corners.
        It needs to be 8dp or less than the value of appWidgetRadius
        -->
        <item name="appWidgetInnerRadius">8dp</item>
    </style>

    <style name="Theme.Spring_2026.AppWidgetContainer" parent="Theme.Spring_2026.AppWidgetContainerParent">
        <!-- Apply padding to avoid the content of the widget colliding with the rounded corners -->
        <item name="appWidgetPadding">16dp</item>
    </style>
</resources>