<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Spring_2026" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="PinBox">
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:background">@drawable/bg_pin_empty</item>
    </style>
    <style name="GreenIndicator">
        <item name="android:color">@android:color/transparent</item>
        <item name="shapeAppearance">@style/RoundedIndicator</item>
    </style>
    <style name="RoundedIndicator">
        <item name="cornerSize">16dp</item>
    </style>
    <style name="PinKeySimple">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_margin">10dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">24sp</item>
        <item name="android:background">@drawable/bg_pin_key</item>
    </style>


    <style name="Theme.Spring_2026" parent="Base.Theme.Spring_2026" />
</resources>